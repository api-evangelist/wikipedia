{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/wikipedia/refs/heads/main/json-structure/rest-v1-thumbnail-structure.json",
  "name": "thumbnail",
  "description": "thumbnail schema from Wikimedia REST API",
  "type": "object",
  "properties": {
