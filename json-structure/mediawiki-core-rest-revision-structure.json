{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/wikipedia/refs/heads/main/json-structure/mediawiki-core-rest-revision-structure.json",
  "name": "Revision",
  "description": "A page revision.",
  "type": "object",
  "properties": {
    "id": {
      "type": "int32",
      "example": 1356767710
    },
    "page": {
      "type": "object",
      "properties": {
        "id": {
          "type": "int32"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "size": {
      "type": "int32",
      "description": "Byte size of revision"
    },
    "minor": {
      "type": "boolean"
    },
    "timestamp": {
      "type": "datetime"
    },
    "content_model": {
      "type": "string",
      "example": "wikitext"
    },
    "license": {
      "type": "object",
      "properties": {
        "url": {
          "type": "uri"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "user": {
      "type": "object",
      "properties": {
        "id": {
          "type": "int32"
        },
        "name": {
          "type": "string",
          "example": "Jimbo Wales"
        }
      }
    },
    "comment": {
      "type": "string",
      "description": "Edit summary"
    },
    "delta": {
      "type": "int32",
      "description": "Byte delta from previous revision"
    }
  }
}