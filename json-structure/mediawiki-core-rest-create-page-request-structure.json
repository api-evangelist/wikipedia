{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/wikipedia/refs/heads/main/json-structure/mediawiki-core-rest-create-page-request-structure.json",
  "name": "CreatePageRequest",
  "description": "CreatePageRequest schema from MediaWiki Core REST API",
  "type": "object",
  "properties": {
    "source": {
      "type": "string",
      "description": "Wikitext source for the new page",
      "example": "'''Hello, world.'''"
    },
    "name": {
      "type": "string",
      "description": "New page title",
      "example": "User:Example/Sandbox"
    },
    "comment": {
      "type": "string",
      "description": "Edit summary",
      "example": "Creating sandbox page"
    },
    "content_model": {
      "type": "string",
      "example": "wikitext"
    },
    "token": {
      "type": "string",
      "description": "CSRF token from Action API"
    }
  },
  "required": [
    "source",
    "title",
    "comment"
  ]
}